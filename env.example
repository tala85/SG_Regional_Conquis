# ============================================================
# VARIABLES DE ENTORNO — BACKEND (sg_regional_conquis)
# ============================================================
# Copiá este archivo como ".env" y completá los valores reales.
# NUNCA subas el .env real al repositorio.
# Este archivo .env.example SÍ se puede subir (no tiene datos reales).
# ============================================================

# --- BASE DE DATOS (PostgreSQL) ---
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL="postgresql://postgres:tu_password_aqui@localhost:5432/conquis_db"

# --- JWT (JSON Web Token) ---
# Generá una clave segura con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NUNCA uses una clave débil como "secreto123" o "desarrollo"
JWT_SECRET="reemplaza_esto_con_una_clave_larga_y_aleatoria_de_al_menos_64_caracteres"

# --- SERVIDOR ---
PORT=3000
NODE_ENV=development   # En producción cambiar a: production

# ============================================================
# VARIABLES DE ENTORNO — FRONTEND (frontend-conquis/.env)
# ============================================================
# Creá también un archivo .env dentro de la carpeta frontend-conquis/
# con el siguiente contenido:
#
# VITE_API_URL=http://localhost:3000
#
# En producción, cambiar por la URL real del servidor:
# VITE_API_URL=https://tu-dominio.com
# ============================================================
